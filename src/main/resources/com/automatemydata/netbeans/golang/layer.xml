<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN"
                            "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!--
        The project's own actions are registered with @ActionReference on GoProject. This link
        cannot be: it points at a folder rather than an action, and only a layer can express that.

        "Projects/Actions" is where other modules contribute the actions every project type should
        have regardless of language — Team/version control, Find, and whatever else is installed.
        Linking to the folder means a Go project picks those up as they are installed, instead of
        this plugin having to know about each of them.
    -->
    <folder name="Projects">
        <folder name="org-automatemydata-netbeans-golang">
            <folder name="Actions">
                <file name="general.shadow">
                    <attr name="originalFile" stringvalue="Projects/Actions"/>
                    <attr intvalue="760" name="position"/>
                </file>
            </folder>
        </folder>
    </folder>
</filesystem>
